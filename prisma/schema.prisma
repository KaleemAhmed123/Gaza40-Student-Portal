generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  student
  mentor
  regional_admin
  master_admin
}

enum AccountStatus {
  pending
  active
  disabled
  rejected
}

enum ProfileStatus {
  draft
  submitted
  under_review
  approved
  changes_requested
  rejected
}

enum VolunteerStatus {
  pending
  approved
  rejected
  inactive
}

enum RegionalAdminStatus {
  active
  inactive
}

enum Sex {
  male
  female
}

enum GazaLocation {
  deir_al_balah
  bureij
  north_gaza
  gaza_city
  nuseirat
  zawaidah
  maghazi
  khan_yunis
  other
}

enum PassportStatus {
  valid
  valid_expires_within_year
  invalid_lost_never_had_one
}

enum PassportLocation {
  in_gaza_with_me
  egypt
  ramallah
  jordan
  other
}

enum DocumentType {
  national_id
  passport
  moi_letter
  consent_form
  offer_letter
  scholarship_letter
  signature
  english_proficiency
}

enum DocumentStatus {
  active
  superseded
  deleted
  failed_scan
}

enum OfferReviewStatus {
  draft
  under_review
  approved
  changes_requested
  rejected
  removed
}

enum QueryStatus {
  open
  assigned @map("in_progress")
  resolved

  @@map("AlertStatus")
}

enum AuthTokenType {
  password_reset
  email_verification
}

model User {
  id                    String                 @id @default(auto()) @map("_id") @db.ObjectId
  email                 String                 @unique
  passwordHash          String
  fullName              String
  phone                 String?
  dateOfBirth           DateTime?
  roles                 RoleCode[]             @default([])
  accountStatus         AccountStatus          @default(active)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  studentProfile        StudentProfile?
  volunteerProfile      VolunteerProfile?
  regionalAdminProfile  RegionalAdminProfile?  @relation("RegionalAdminUser")
  regionalAdminsCreated RegionalAdminProfile[] @relation("RegionalAdminAssignedBy")
  studentOffers         Offer[]                @relation("StudentOffers")
  mentorOffers          Offer[]                @relation("OfferMentor")
  documents             Document[]
  offerReviews          OfferRevision[]
  studentQueries        Query[]                @relation("StudentQueries")
  assignedQueries       Query[]                @relation("AssignedQueries")
  assignedQueriesByMe   Query[]                @relation("QueryAssignmentsCreated")
  queryMessages         QueryMessage[]
  announcements         Announcement[]
  auditLogs             AuditLog[]
  authTokens            AuthToken[]
  notifications         Notification[]
  chatMemberships       ConversationMember[]
  chatMessages          ChatMessage[]
  csvJobs               CsvJob[]

  @@index([accountStatus])
}

model StudentProfile {
  id                                  String            @id @default(auto()) @map("_id") @db.ObjectId
  userId                              String            @unique @db.ObjectId
  fullNameEnglish                     String?
  sex                                 Sex?
  dateOfBirth                         DateTime?
  locationInGaza                      GazaLocation?
  locationOther                       String?
  hasOfferSelfReported                Boolean           @default(false)
  hasVerifiedOffer                    Boolean           @default(false)
  passportStatus                      PassportStatus?
  passportLocation                    PassportLocation?
  passportLocationOther               String?
  emergencyContactFirstName           String?
  emergencyContactRelation            String?
  emergencyContactPhone               String?
  englishMoi                          Boolean?
  bachelorUniGaza                     String?
  englishWorkplaceCertificatePossible Boolean?
  englishOtherCerts                   String?
  consentSigned                       Boolean           @default(false)
  profileStatus                       ProfileStatus     @default(draft)
  reviewedBy                          String?           @db.ObjectId
  reviewedAt                          DateTime?
  reviewNotes                         String?
  createdAt                           DateTime          @default(now())
  updatedAt                           DateTime          @updatedAt
  deletedAt                           DateTime?
  user                                User              @relation(fields: [userId], references: [id])
  documents                           Document[]

  @@index([profileStatus])
}

model VolunteerProfile {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  userId                String          @unique @db.ObjectId
  universityAffiliation String?
  preferredRegionId     String?         @db.ObjectId
  volunteerStatus       VolunteerStatus @default(pending)
  reviewedBy            String?         @db.ObjectId
  reviewedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?
  user                  User            @relation(fields: [userId], references: [id])

  @@index([volunteerStatus])
}

model RegionalAdminProfile {
  id               String              @id @default(auto()) @map("_id") @db.ObjectId
  userId           String              @unique @db.ObjectId
  regionId         String              @db.ObjectId
  status           RegionalAdminStatus @default(active)
  assignedByUserId String?             @db.ObjectId
  plainPassword    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  user             User                @relation("RegionalAdminUser", fields: [userId], references: [id])
  region           Region              @relation(fields: [regionId], references: [id])
  assignedBy       User?               @relation("RegionalAdminAssignedBy", fields: [assignedByUserId], references: [id])

  @@index([regionId])
  @@index([status])
}

model Region {
  id                    String                 @id @default(auto()) @map("_id") @db.ObjectId
  code                  String                 @unique @map("countryCode")
  name                  String                 @unique @map("countryName")
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt
  deletedAt             DateTime?
  regionalAdminProfiles RegionalAdminProfile[]
  universities          University[]
  offers                Offer[]
  queries               Query[]

  @@index([isActive])
}

model University {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  regionId  String    @db.ObjectId
  name      String
  city      String?
  isLondon  Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  region    Region    @relation(fields: [regionId], references: [id])
  offers    Offer[]

  @@unique([regionId, name])
  @@index([regionId])
  @@index([isActive])
}

model ConfigOption {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  groupKey  String
  value     String
  labelEn   String
  labelAr   String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([groupKey, value])
  @@index([groupKey, isActive])
}

model Offer {
  id                          String            @id @default(auto()) @map("_id") @db.ObjectId
  studentUserId               String            @db.ObjectId
  regionId                    String            @db.ObjectId
  universityId                String?           @db.ObjectId
  universityName              String
  courseName                  String
  courseField                 String
  courseLevel                 String
  durationYears               Float
  programmeStartDate          DateTime
  offerType                   String
  conditions                  String?
  tuitionFeePerYear           Float
  courseFeeSourceUrl          String?
  hasScholarship              Boolean           @default(false)
  scholarshipName             String?
  scholarshipAmountPerYear    Float?
  scholarshipCoversLivingCost Boolean           @default(false)
  privateFundingAmount        Float             @default(0)
  privateFundingSource        String?
  livingCostLocationKey       String?
  livingCostForVisa           Float?
  boardingFees                Float?
  reviewStatus                OfferReviewStatus @default(draft)
  lockedForReview             Boolean           @default(false)
  mentorId                    String?           @db.ObjectId
  reviewedBy                  String?           @db.ObjectId
  reviewedAt                  DateTime?
  reviewNotes                 String?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  deletedAt                   DateTime?
  student                     User              @relation("StudentOffers", fields: [studentUserId], references: [id])
  region                      Region            @relation(fields: [regionId], references: [id])
  university                  University?       @relation(fields: [universityId], references: [id])
  mentor                      User?             @relation("OfferMentor", fields: [mentorId], references: [id])
  documents                   Document[]
  revisions                   OfferRevision[]
  queries                     Query[]

  @@index([studentUserId])
  @@index([regionId])
  @@index([universityId])
  @@index([mentorId])
  @@index([reviewStatus])
  @@index([offerType])
  @@index([universityName])
  @@index([courseField])
  @@index([courseLevel])
  @@index([createdAt])
}

model OfferRevision {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  offerId       String   @db.ObjectId
  editedBy      String   @db.ObjectId
  beforeData    Json
  afterData     Json
  changedFields String[]
  createdAt     DateTime @default(now())
  offer         Offer    @relation(fields: [offerId], references: [id])
  editor        User     @relation(fields: [editedBy], references: [id])

  @@index([offerId])
  @@index([editedBy])
  @@index([createdAt])
}

model Document {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  ownerUserId      String          @db.ObjectId
  studentProfileId String?         @db.ObjectId
  offerId          String?         @db.ObjectId
  documentType     DocumentType
  originalFilename String
  mimeType         String
  fileSizeBytes    Int
  storageBucket    String
  storageKey       String
  status           DocumentStatus  @default(active)
  uploadedBy       String          @db.ObjectId
  createdAt        DateTime        @default(now())
  deletedAt        DateTime?
  owner            User            @relation(fields: [ownerUserId], references: [id])
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id])
  offer            Offer?          @relation(fields: [offerId], references: [id])

  @@index([ownerUserId])
  @@index([studentProfileId])
  @@index([offerId])
  @@index([documentType])
  @@index([status])
}

model Query {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  studentUserId    String         @db.ObjectId
  offerId          String?        @db.ObjectId
  regionId         String?        @db.ObjectId
  queryType        String         @map("alertType")
  title            String
  message          String
  status           QueryStatus    @default(open)
  assignedToUserId String?        @db.ObjectId
  assignedByUserId String?        @db.ObjectId
  acceptedAt       DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  student          User           @relation("StudentQueries", fields: [studentUserId], references: [id])
  offer            Offer?         @relation(fields: [offerId], references: [id])
  region           Region?        @relation(fields: [regionId], references: [id])
  assignedTo       User?          @relation("AssignedQueries", fields: [assignedToUserId], references: [id])
  assignedBy       User?          @relation("QueryAssignmentsCreated", fields: [assignedByUserId], references: [id])
  messages         QueryMessage[]

  @@index([studentUserId])
  @@index([offerId])
  @@index([regionId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([queryType])
  @@map("Alert")
}

model QueryMessage {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  queryId      String    @map("alertId") @db.ObjectId
  senderUserId String    @db.ObjectId
  message      String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  query        Query     @relation(fields: [queryId], references: [id])
  sender       User      @relation(fields: [senderUserId], references: [id])

  @@index([queryId])
  @@index([senderUserId])
  @@index([createdAt])
  @@map("AlertMessage")
}

model Announcement {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  body            String
  category        String?
  createdByUserId String    @db.ObjectId
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       User      @relation(fields: [createdByUserId], references: [id])

  @@index([createdByUserId])
  @@index([isPublished])
  @@index([category])
}

model AppConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuthToken {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  userId    String        @db.ObjectId
  tokenHash String        @unique
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId, type])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  actorUserId String?  @db.ObjectId
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  type      String   // e.g., "chat_message", "profile_approved"
  title     String
  body      String
  link      String?  // Optional URL to navigate to when clicked
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
}

model Conversation {
  id            String               @id @default(auto()) @map("_id") @db.ObjectId
  type          ConversationType     // direct | group
  name          String?              // null for direct, required for group
  createdBy     String               @db.ObjectId
  lastMessageAt DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  members       ConversationMember[]
  messages      ChatMessage[]

  @@index([type])
  @@index([lastMessageAt])
}

model ConversationMember {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  conversationId   String       @db.ObjectId
  userId           String       @db.ObjectId
  role             MemberRole   @default(member)  // admin | member
  lastReadAt       DateTime?
  joinedAt         DateTime     @default(now())
  removedAt        DateTime?
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model ChatMessage {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  conversationId   String        @db.ObjectId
  senderUserId     String        @db.ObjectId
  content          String?       // text content
  clientMessageId  String?       // idempotency key from client
  attachmentUrl    String?       // R2 object URL (signed/proxied)
  attachmentName   String?       // original filename
  attachmentSize   Int?          // bytes
  attachmentType   String?       // mime type
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           User          @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@index([clientMessageId])
  @@index([createdAt])    // for retention cleanup
}

enum ConversationType {
  direct
  group
}

enum MemberRole {
  admin
  member
}

enum CsvDataset {
  students
  mentors
  regional_admins
}

enum CsvJobStatus {
  pending
  generating
  completed
  failed
  expired
}

model CsvJob {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  requestedByUserId    String        @db.ObjectId
  dataset              CsvDataset
  status               CsvJobStatus  @default(pending)
  csvVersion           String        // e.g. "students-v1"
  filters              Json?         // full filter object stored for audit / duplicate detection
  filterSummary        String?       // human-readable display string e.g. "Country: UK"
  columns              String[]      @default([])
  dateRangeField       String
  dateRangeFrom        DateTime
  dateRangeTo          DateTime
  cancelRequested      Boolean       @default(false)
  // R2 storage
  storageBucket        String?
  storageKey           String?       // csv-exports/YYYY/MM/<dataset>/<jobId>.csv
  // Progress (no estimatedRows — avoids expensive COUNT; UI shows live processedRows)
  processedRows        Int           @default(0)
  // Completion metadata
  rowCount             Int?
  fileSizeBytes        Int?
  generationDurationMs Int?
  errorMessage         String?
  expiresAt            DateTime?     // now + CSV_SIGNED_URL_TTL_DAYS on completion
  completedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  requestedBy          User          @relation(fields: [requestedByUserId], references: [id])

  @@index([requestedByUserId])
  @@index([status])
  @@index([dataset])
  @@index([expiresAt])
  @@index([createdAt])
}
